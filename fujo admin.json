        {
            "parameters": {
                "jsCode": "const newItems = [];\n\nfor (const item of $input.all()) {\n  // 1. Forzar un objeto puro (limpia Proxies de n8n)\n  const safeJson = JSON.parse(JSON.stringify(item.json || {}));\n  \n  const newItem = { json: safeJson };\n\n  // 2. Normalizar el binario\n  if (item.binary) {\n    newItem.binary = {};\n    const keys = Object.keys(item.binary);\n    \n    for (const key of keys) {\n      newItem.binary[key] = item.binary[key];\n    }\n    \n    if (keys.length > 0 && !newItem.binary.data) {\n      newItem.binary.data = item.binary[keys[0]];\n    }\n  }\n\n  newItems.push(newItem);\n}\n\nreturn newItems;"
            },
